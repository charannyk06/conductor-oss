{
  "name": "conductor-oss-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Conductor Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/charannyk06/conductor-oss.git"
  },
  "description": "Markdown-native AI agent orchestrator — dispatch coding tasks from a kanban board",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:release": "pnpm --filter='!@conductor-oss/web' build && pnpm --filter @conductor-oss/web build",
    "changeset": "changeset",
    "dev": "pnpm --filter @conductor-oss/web dev",
    "executor:build": "cargo build --manifest-path orchestrator/runtime-sidecar/Cargo.toml --release",
    "executor:dev": "cargo run --manifest-path orchestrator/runtime-sidecar/Cargo.toml",
    "release": "pnpm build:release && pnpm release:verify && pnpm release:publish",
    "release:pack": "node scripts/pack-cli-package.mjs",
    "release:publish": "node scripts/publish-cli-package.mjs",
    "release:verify": "node scripts/verify-cli-package.mjs",
    "sync:versions": "node scripts/sync-package-versions.mjs",
    "typecheck": "pnpm --filter @conductor-oss/core build && pnpm -r typecheck",
    "test": "pnpm --filter @conductor-oss/core test",
    "clean": "pnpm -r clean",
    "ui:screenshots": "node scripts/capture-dashboard-screenshots.mjs",
    "version-packages": "changeset version && pnpm sync:versions && pnpm install --lockfile-only"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.3.3",
    "puppeteer": "^24.37.5",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/charannyk06/conductor-oss",
  "keywords": [
    "ai",
    "agent",
    "coding",
    "kanban",
    "orchestrator",
    "claude",
    "codex",
    "automation"
  ]
}
