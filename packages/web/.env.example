# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional hosted Clerk Account Portal URLs.
# Example:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://accounts.conductross.com/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://accounts.conductross.com/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
# Optional proxy path for Clerk Frontend API route handlers.
# Only set this on deployments whose Clerk instance is configured to accept proxy handshakes.
NEXT_PUBLIC_CLERK_PROXY_URL=
# Optional stable hosted origins for Clerk redirect validation and action-origin checks.
# Example: https://app.conductross.com,https://preview.conductross.com
CONDUCTOR_ALLOWED_ORIGINS=

# Access control
# Comma-separated exact emails that can access dashboard
CONDUCTOR_ALLOWED_EMAILS=

# Optional admin bypass list (skips manual approval)
CONDUCTOR_ADMIN_EMAILS=

# Optional domains allowed (comma-separated), example: autma.ai,example.com
CONDUCTOR_ALLOWED_DOMAINS=

# Require publicMetadata.conductorApproved=true for non-admins
CONDUCTOR_REQUIRE_APPROVAL=true

# Force the hosted pair-first flow even during local testing.
CONDUCTOR_REQUIRE_PAIRED_DEVICE=false
