{
  "name": "conductor-oss",
  "version": "0.2.8",
  "license": "MIT",
  "type": "module",
  "bin": {
    "conductor-oss": "dist/launcher.js",
    "conductor": "dist/launcher.js",
    "co": "dist/launcher.js"
  },
  "main": "dist/launcher.js",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/launcher.ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "node ../../scripts/verify-cli-publish-manifest.mjs"
  },
  "dependencies": {
    "@conductor-oss/core": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "description": "Markdown-native AI agent orchestrator. Write tasks in a kanban board, agents do the work.",
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "kanban",
    "claude",
    "codex",
    "automation",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/charannyk06/conductor-oss",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/charannyk06/conductor-oss",
  "bugs": {
    "url": "https://github.com/charannyk06/conductor-oss/issues"
  }
}
