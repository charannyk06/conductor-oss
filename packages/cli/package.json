    "@conductor-oss/plugin-agent-cursor-cli": "0.2.8",
    "@conductor-oss/plugin-agent-opencode": "0.2.8",
    "@conductor-oss/plugin-agent-droid": "0.2.8",
    "@conductor-oss/plugin-agent-qwen-code": "0.2.8",
    "@conductor-oss/plugin-agent-ccr": "0.2.8",
    "@conductor-oss/plugin-agent-github-copilot": "0.2.8",
    "@conductor-oss/plugin-mcp-server": "0.2.8",
