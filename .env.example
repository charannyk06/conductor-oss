# Shared Conductor runtime env

# GitHub webhook signing secret used by /api/github/webhook
CONDUCTOR_GITHUB_WEBHOOK_SECRET=

# Shared secret used by the Next.js dashboard when forwarding authenticated
# access headers to a remotely exposed Rust backend. Required when
# CONDUCTOR_UNSAFE_ALLOW_REMOTE_BACKEND=true and auth is enabled.
# CONDUCTOR_PROXY_AUTH_SECRET=

# Allow the server-side preview browser to connect to private-network hosts
# other than loopback. Leave unset for the safer default.
# CONDUCTOR_ALLOW_UNSAFE_PREVIEW_HOSTS=false

# Optional port overrides
PORT=4747
CONDUCTOR_BACKEND_PORT=4748

# Optional alternate env file path for package scripts
# CONDUCTOR_ENV_FILE=/absolute/path/to/.env.local

# Optional Clerk web auth
# Use Clerk development keys for Vercel preview/development environments.
# Use Clerk production keys only on your custom production domain.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_HOSTED_SIGN_IN_URL=https://accounts.example.com/sign-in
